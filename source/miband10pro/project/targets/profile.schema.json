{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sep1107/miband-watchfaces/source/miband10pro/project/targets/profile.schema.json",
  "title": "TIME FLIES Smart Band target profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "width",
    "height",
    "panelX",
    "panelPadding",
    "status",
    "evidence"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "panelX": { "type": "integer", "minimum": 1 },
    "panelPadding": { "type": "integer", "minimum": 0 },
    "status": {
      "enum": [
        "reference-build-chain",
        "reported-hardware",
        "verified-build-target"
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["hardware", "buildChain", "deviceTarget", "sources"],
      "properties": {
        "hardware": { "enum": ["none", "indirect", "reported", "official"] },
        "buildChain": { "enum": ["none", "reference", "tested"] },
        "deviceTarget": { "enum": ["unverified", "reference-only", "verified"] },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
